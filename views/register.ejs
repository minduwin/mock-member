<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <title><%= title %></title>
</head>
<body>
    <%- include('partials/sidebar') %>
    <div class="register">
        <div class="registerForm">
            <form action="/register" method="POST">
                <div class="login-Info">
                    <h3>Create Account</h3>
                    <p>Join our community and share your thoughts</p>
                </div>
                <div class="input-group">
                    <div class="input-icon">
                        <span class="material-symbols-outlined">person</span>
                    </div>
                    <input type="text" id="firstname" name="firstname" required>
                    <label for="firstname">First Name</label>
                </div>
                <div class="input-group">
                    <div class="input-icon">
                        <span class="material-symbols-outlined">person</span>
                    </div>
                    <input type="text" id="lastname" name="lastname" required>
                    <label for="lastname">Last Name</label>
                </div>
                <div class="input-group">
                    <div class="input-icon">
                        <span class="material-symbols-outlined">face</span>
                    </div>
                    <input type="text" id="username" name="username" required>
                    <label for="username">Username</label>
                </div>
                <div class="input-group">
                    <div class="input-icon">
                        <span class="material-symbols-outlined">lock</span>
                    </div>
                    <input type="password" id="password" name="password" required>
                    <label for="password">Password</label>
                </div>
                <div class="input-group">
                    <div class="input-icon">
                        <span class="material-symbols-outlined">lock_person</span>
                    </div>
                    <input type="password" id="confirmPwd" name="confirmPwd" required>
                    <label for="confirmPwd">Confirm Password</label>
                </div>
                <div class="registerBtn">
                    <button type="submit">Sign up</button>
                </div>
                <div class="login-options">
                    <div class="option-info">
                        <hr class="horizontal-line">
                        <span>or continue with</span>
                        <hr class="horizontal-line">
                    </div>
                    <div class="option-button">
                        <div class="option-icon">
                            <img src="/icons/google.svg" alt="">
                        </div>
                        <div class="option-icon">
                            <img src="/icons/apple.svg" alt="">
                        </div>
                        <div class="option-icon">
                            <img src="/icons/facebook.svg" alt="">
                        </div>
                    </div>
                </div>
                <div class="option-signup">
                    <span>
                        Already have an account?
                        <a href="/login">Log in!</a>
                    </span>
                </div>
            </form>
        </div>
    </div>
</body>
</html>