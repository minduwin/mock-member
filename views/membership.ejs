<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title><%= title %></title>
</head>
<body>
    <main class="memberContainer">
        <div class="user-status">
            <%- include('partials/status') %>
        </div>
        <div class="disclaimer">
            <div class="discInfo">
                <h3>Become a Member of the Secret Club</h3>
                <p>To see who posted the messages and on what date, click the button below to become an official member.</p>
            </div>
            <div class="memberForm">
                <form method="POST" action="/membership">
                    <div class="activateForm">
                        <input type="checkbox" id="agree" name="agree" required>
                        <label for="agree">I want to become a member and view all the message details.</label>
                    </div>
                    <div class="activateBtn">
                        <button type="submit">Activate</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="user-sidebar">
            <%- include('partials/sidebar') %>
        </div>
    </main>
</body>
</html>